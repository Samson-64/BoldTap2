# Backend Environment Configuration
# Copy this file to .env and update values for your environment

# ============ SERVER CONFIGURATION ============
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# ============ FRONTEND CONFIGURATION ============
FRONTEND_URL=http://localhost:3000

# ============ SECURITY CONFIGURATION ============
# IMPORTANT: Generate a secure JWT secret for production!
# Run: openssl rand -hex 64
# Or: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ============ DATABASE CONFIGURATION ============
# For development, use in-memory database (no setup needed)
# For production, set up PostgreSQL, MongoDB, or other database
DATABASE_TYPE=in-memory
DATABASE_URL=sqlite:./dev.db

# ============ RATE LIMITING CONFIGURATION ============
# Rate limit window (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (general endpoints)
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window (auth endpoints - stricter)
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# ============ OPTIONAL CONFIGURATION ============
# Logging
LOG_LEVEL=debug

# Email (for future password reset functionality)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@boldtap.com
